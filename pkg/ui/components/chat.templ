package components

// Templ component: main chat container.
//
// Renders the full chat UI: message list + input form.
// Uses Datastar data-signals for reactive state.

templ Chat() {
	<div id="chat" data-signals="{messages: [], status: 'idle', error: null}" data-connect="/chat/stream">
		<div id="chat-messages" data-on-signal-change="$$append(messages)">
			// Messages rendered here via SSE updates
		</div>
		@ChatInput()
	</div>
}
