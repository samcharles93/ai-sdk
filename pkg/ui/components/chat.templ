package chat

// Templ component: main chat container.
//
// Renders the full chat UI: message list + input form.
// Uses Datastar data-signals for reactive state.

templ Chat() {
	<div id="chat" data-signals="{}">
		<div id="chat-messages" data-signals="{}">
			// Messages rendered here via SSE updates
		</div>
		@ChatInput()
	</div>
}
